<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.YhchatCanary" parent="android:Theme.Material.Light.NoActionBar">
        <!-- 状态栏透明 -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <!-- 状态栏文字颜色为深色 -->
        <item name="android:windowLightStatusBar">true</item>
        <!-- 导航栏透明 -->
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- 导航栏文字颜色为深色 -->
        <item name="android:windowLightNavigationBar">true</item>
        <!-- 启用边到边显示 -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <style name="Theme.YhchatCanary.Wear" parent="Theme.SplashScreen">
        <item name="android:enableOnBackInvokedCallback">true</item>
        <item name="android:windowSwipeToDismiss">true</item>
        <item name="windowSplashScreenBackground">@android:color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@android:style/Theme.DeviceDefault</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
    </style>
</resources>