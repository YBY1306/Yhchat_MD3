<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-feature android:name="android.hardware.type.watch" />
    <application
        android:name="com.yhchat.canary.WatchApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.YhchatCanary"
        tools:replace="android:name">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.YhchatCanary"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.chat.ChatActivity"
            android:allowEmbedded="true"
            android:exported="false"
            android:label="聊天"
            android:resizeableActivity="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.YhchatCanary" />
        <activity
            android:name=".ui.login.TokenLoginActivity"
            android:exported="true"
            android:label="登录"
            android:theme="@style/Theme.YhchatCanary">
        </activity>
        <activity android:name="com.yhchat.canary.ui.chat.ChatAddActivity" tools:node="remove"/>
        <activity
            android:name=".ui.chat.ChatAddActivity"
            android:exported="true"
            android:label="添加聊天"
            android:theme="@style/Theme.YhchatCanary">
            <!-- 处理yunhu://chat-add链接 -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="yunhu"
                    android:host="chat-add" />
                <data android:scheme="https"
                    android:host="yhfx.jwznb.com" />
                <data android:scheme="yunhu"
                    android:host="jwznb.com" />
            </intent-filter>
        </activity>
        <activity-alias
            android:name="com.yhchat.canary.ui.chat.ChatAddActivity"
            android:targetActivity=".ui.chat.ChatAddActivity"
            android:exported="true"
            android:label="添加聊天">
            <!-- 处理yunhu://chat-add链接 -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="yunhu"
                    android:host="chat-add" />
                <data android:scheme="https"
                    android:host="yhfx.jwznb.com" />
                <data android:scheme="yunhu"
                    android:host="jwznb.com" />
            </intent-filter>
        </activity-alias>
        <activity android:name="com.yhchat.canary.ui.sticker.StickerPackDetailActivity" tools:node="remove"/>
        <activity
            android:name=".ui.sticker.StickerPackDetailActivity"
            android:exported="false"
            android:label="表情包详情"
            android:theme="@style/Theme.YhchatCanary" />
        <activity-alias
            android:name="com.yhchat.canary.ui.sticker.StickerPackDetailActivity"
            android:targetActivity=".ui.sticker.StickerPackDetailActivity"
            android:exported="false"
            android:label="表情包详情"/>
    </application>

</manifest>